# =============================================================================
# EquiSaaS BD - Local environment template (single source of truth)
# =============================================================================
# Copy this file to `.env` at the repo root and fill in the real values.
# The real `.env` is git-ignored. Never commit a real .env.
#
# All app, deploy, SEO, and analytics keys live here. There is no
# .env.seo.local split. The SEO scripts read from this file first.
#
# Loader behavior:
#   - landing (Vite) reads `VITE_*` keys at build time and in the browser.
#   - lms (Next.js, static export) reads `NEXT_PUBLIC_*` keys at build time
#     and in the browser. Server-only keys (without the prefix) are NOT
#     available in the static export, so everything the LMS browser bundle
#     needs must be prefixed with `NEXT_PUBLIC_`.
#   - scripts/cloudflare/* reads `CLOUDFLARE_*` keys.
#   - scripts/seo/* reads `BING_*`, `GOOGLE_*`, `GA4_*` keys from this file.
# =============================================================================


# -----------------------------------------------------------------------------
# Cloudflare automation (CLI only, not bundled)
# -----------------------------------------------------------------------------
# Used by `scripts/cloudflare/*`. Recommended minimum token scopes:
#   - token verify
#   - zone read
#   - DNS read
#   - cache purge
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_NAME=equisaas-bd.com
CLOUDFLARE_ZONE_ID=


# -----------------------------------------------------------------------------
# Bing Webmaster Tools
# -----------------------------------------------------------------------------
# https://www.bing.com/webmasters > Settings > API Access > Generate API Key.
BING_WEBMASTER_API_KEY=


# -----------------------------------------------------------------------------
# Google PageSpeed Insights
# -----------------------------------------------------------------------------
# https://console.cloud.google.com/apis/credentials > Create API key.
GOOGLE_PAGESPEED_API_KEY=


# -----------------------------------------------------------------------------
# Google OAuth Desktop App credentials (for Search Console + GA4)
# -----------------------------------------------------------------------------
# Path to the downloaded OAuth client JSON. The token is cached next to it
# at `artifacts/secrets/google-seo-token.json` (git-ignored).
GOOGLE_OAUTH_CLIENT_JSON=D:\projects\EquiSaaS BD\artifacts\secrets\google-seo-oauth-client.json


# -----------------------------------------------------------------------------
# Google Analytics 4 (optional)
# -----------------------------------------------------------------------------
GA4_PROPERTY_ID=


# -----------------------------------------------------------------------------
# Microsoft Clarity (session analytics, optional)
# -----------------------------------------------------------------------------
VITE_CLARITY_PROJECT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=


# -----------------------------------------------------------------------------
# Firebase client (browser) - landing (Vite) and lms (Next.js, static export)
# -----------------------------------------------------------------------------
# Find these in the Firebase console: Project settings > General > Your apps.
# apiKey is public-by-design in client apps, not a secret.

# Landing (Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# LMS (Next.js static export)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=


# -----------------------------------------------------------------------------
# Web Push VAPID (LMS notifications, optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_VAPID_KEY=


# -----------------------------------------------------------------------------
# Google Gemini (optional, AI features)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
